//@version=6
indicator("Markov Regime Enhanced v2", overlay=false, max_bars_back=500, shorttitle="Markov v2")

// --- INPUTS ---
lookback         = input.int(21,    "Lookback Bars",           minval=5,  maxval=100)
bull_threshold   = input.float(3.0, "Bull-Schwelle %",         minval=0.5, maxval=10, step=0.5)
bear_threshold   = input.float(3.0, "Bear-Schwelle %",         minval=0.5, maxval=10, step=0.5)
sticky_warn_bull = input.float(60.0,"Bull-Warn-Schwelle %",    minval=20, maxval=95,  step=5)
sticky_warn_bear = input.float(55.0,"Bear-Warn-Schwelle %",    minval=20, maxval=95,  step=5)
smooth_len       = input.int(5,     "Glaettung EMA",           minval=1,  maxval=20)
show_bull_line   = input.bool(true, "Bull-Stickiness anzeigen")
show_bear_line   = input.bool(true, "Bear-Stickiness anzeigen")
show_side_line   = input.bool(false,"Sideways-Stickiness anzeigen")
show_regime_bg   = input.bool(true, "Hintergrund nach Regime")
show_transitions = input.bool(true, "Regime-Wechsel markieren")

// --- TIMEFRAME-VALIDIERUNG ---
tf_minutes      = timeframe.in_seconds() / 60
min_tf_minutes  = 1950.0 / lookback
tf_too_short    = tf_minutes < min_tf_minutes

recommended_tf  = min_tf_minutes < 60   ? str.tostring(math.round(min_tf_minutes)) + " min" :
                  min_tf_minutes < 1440 ? str.tostring(math.round(min_tf_minutes / 60)) + "H" : "Daily"

// --- REGIME-KLASSIFIKATION ---
log_return     = math.log(close / close[lookback]) * 100
current_regime = log_return > bull_threshold ? 1 : log_return < -bear_threshold ? -1 : 0

// --- TRANSITION-ZAEHLUNG ---
float bb = 0, bn = 0, bc = 0
float nb = 0, nn = 0, nc = 0
float cb = 0, cn = 0, cc = 0

for i = 1 to lookback
    prev = current_regime[i]
    curr = current_regime[i - 1]
    if prev == 1
        if curr == 1
            bb += 1
        else if curr == 0
            bn += 1
        else
            bc += 1
    else if prev == 0
        if curr == 1
            nb += 1
        else if curr == 0
            nn += 1
        else
            nc += 1
    else
        if curr == 1
            cb += 1
        else if curr == 0
            cn += 1
        else
            cc += 1

bull_total = bb + bn + bc
bear_total = cb + cn + cc
side_total = nb + nn + nc

bull_sticky_raw = bull_total > 0 ? bb / bull_total * 100 : 50.0
bear_sticky_raw = bear_total > 0 ? cc / bear_total * 100 : 50.0
side_sticky_raw = side_total > 0 ? nn / side_total * 100 : 50.0

bull_sticky = ta.ema(bull_sticky_raw, smooth_len)
bear_sticky = ta.ema(bear_sticky_raw, smooth_len)
side_sticky = ta.ema(side_sticky_raw, smooth_len)

// --- REGIME-WECHSEL ---
prev_regime    = current_regime[1]
bull_to_bear   = prev_regime == 1  and current_regime == -1
bear_to_bull   = prev_regime == -1 and current_regime == 1
bull_weakening = current_regime == 1 and bull_sticky < sticky_warn_bull

// --- ALERT-BEDINGUNGEN ---
bull_sticky_warning = bull_sticky < sticky_warn_bull and bull_sticky[1] >= sticky_warn_bull
bear_sticky_warning = bear_sticky > sticky_warn_bear and bear_sticky[1] <= sticky_warn_bear
direct_reversal     = bull_to_bear or bear_to_bull

alertcondition(bull_sticky_warning, title="Bull-Stickiness gefallen",
     message="WARNUNG: Bull-Persistenz fuer {{ticker}} unter Schwelle!")
alertcondition(bear_sticky_warning, title="Bear-Regime festigt sich",
     message="ACHTUNG: Bear-Persistenz fuer {{ticker}} ueber Schwelle!")
alertcondition(direct_reversal,     title="Direkter Regime-Wechsel",
     message="DIREKTER WECHSEL bei {{ticker}}: Bull-Bear oder Bear-Bull!")
alertcondition(bull_weakening,      title="Bull-Regime schwaechelt",
     message="Bull aktiv aber Stickiness schwach bei {{ticker}}. Vorsicht!")

// --- HINTERGRUND ---
bg_col = current_regime == 1  ? color.new(color.green, 88) :
         current_regime == -1 ? color.new(color.red,   88) :
         color.new(color.gray, 92)
bgcolor(show_regime_bg and not tf_too_short ? bg_col : na)

// --- REFERENZLINIEN (feste Werte, kein hline mit dynamischem price) ---
hline(80, "Sehr klebrig",  color=color.new(color.gray, 60), linestyle=hline.style_dotted)
hline(60, "Moderat",       color=color.new(color.gray, 50), linestyle=hline.style_dashed)
hline(40, "Schwach",       color=color.new(color.gray, 50), linestyle=hline.style_dashed)

// Bull-Warnschwelle als plot statt hline (darf dynamisch sein)
plot(sticky_warn_bull, "Bull-Warnschwelle",
     color=color.new(color.green, 30), linewidth=1, style=plot.style_line)

// --- PLOTS ---
plot(show_bull_line and not tf_too_short ? bull_sticky : na,
     title="Bull Stickiness", color=color.new(color.green, 0), linewidth=2)
plot(show_bear_line and not tf_too_short ? bear_sticky : na,
     title="Bear Stickiness", color=color.new(color.red, 0), linewidth=2)
plot(show_side_line and not tf_too_short ? side_sticky : na,
     title="Sideways Stickiness", color=color.new(color.gray, 20), linewidth=1)
plot(bull_weakening and not tf_too_short ? bull_sticky : na,
     title="Bull schwaechelt", color=color.new(color.orange, 0), linewidth=3)

plotshape(show_transitions and bull_to_bear and not tf_too_short ? bear_sticky : na,
     title="Bull-Bear Wechsel", location=location.absolute,
     style=shape.xcross, color=color.red, size=size.normal)
plotshape(show_transitions and bear_to_bull and not tf_too_short ? bull_sticky : na,
     title="Bear-Bull Wechsel", location=location.absolute,
     style=shape.circle, color=color.green, size=size.normal)
plotshape(bull_sticky_warning and not tf_too_short ? bull_sticky : na,
     title="Bull-Warnung", location=location.absolute,
     style=shape.labeldown, color=color.orange,
     text="WARN", textcolor=color.white, size=size.small)

// --- INFO-TABLE ---
var table info = table.new(position.top_right, 2, 7,
     bgcolor=color.new(color.black, 70),
     border_color=color.new(color.gray, 40), border_width=1,
     frame_color=color.new(color.gray, 30), frame_width=1)

if barstate.islast
    if tf_too_short
        table.cell(info, 0, 0, "!! TIMEFRAME ZU KURZ !!",
             text_color=color.red, text_size=size.normal,
             bgcolor=color.new(color.red, 75))
        table.cell(info, 1, 0, "",
             bgcolor=color.new(color.red, 75))
        table.cell(info, 0, 1, "Aktuell:",    text_color=color.silver, text_size=size.small)
        table.cell(info, 1, 1, str.tostring(math.round(tf_minutes)) + " min",
             text_color=color.orange, text_size=size.small)
        table.cell(info, 0, 2, "Minimum:",    text_color=color.silver, text_size=size.small)
        table.cell(info, 1, 2, recommended_tf,
             text_color=color.yellow, text_size=size.small)
        table.cell(info, 0, 3, "Lookback:",   text_color=color.silver, text_size=size.small)
        table.cell(info, 1, 3, str.tostring(lookback) + " Bars",
             text_color=color.silver, text_size=size.small)
        table.cell(info, 0, 4, "Ergebnis:",   text_color=color.silver, text_size=size.small)
        table.cell(info, 1, 4, "Nur Rauschen",text_color=color.red,    text_size=size.small)
        table.cell(info, 0, 5, "Empfehlung:", text_color=color.silver, text_size=size.small)
        table.cell(info, 1, 5, "TF erhoehen", text_color=color.yellow, text_size=size.small)
        table.cell(info, 0, 6, "oder Lookback reduzieren", text_color=color.silver, text_size=size.small)
        table.cell(info, 1, 6, "",            text_color=color.silver, text_size=size.small)
    else
        regime_str = current_regime == 1 ? "BULL" : current_regime == -1 ? "BEAR" : "SIDE"
        regime_col = current_regime == 1 ? color.green : current_regime == -1 ? color.red : color.gray
        warn_str   = bull_weakening ? "JA - Vorsicht!" : "nein"
        warn_col   = bull_weakening ? color.orange : color.gray
        table.cell(info, 0, 0, "Regime",          text_color=color.silver, text_size=size.small)
        table.cell(info, 1, 0, regime_str,         text_color=regime_col,   text_size=size.small)
        table.cell(info, 0, 1, "Bull Sticky",      text_color=color.silver, text_size=size.small)
        table.cell(info, 1, 1, str.tostring(bull_sticky, "#.1f") + "%",
             text_color=bull_sticky < sticky_warn_bull ? color.orange : color.green, text_size=size.small)
        table.cell(info, 0, 2, "Bear Sticky",      text_color=color.silver, text_size=size.small)
        table.cell(info, 1, 2, str.tostring(bear_sticky, "#.1f") + "%",
             text_color=bear_sticky > sticky_warn_bear ? color.red : color.gray, text_size=size.small)
        table.cell(info, 0, 3, "Side Sticky",      text_color=color.silver, text_size=size.small)
        table.cell(info, 1, 3, str.tostring(side_sticky, "#.1f") + "%",
             text_color=color.gray, text_size=size.small)
        table.cell(info, 0, 4, "Bull schwaechelt", text_color=color.silver, text_size=size.small)
        table.cell(info, 1, 4, warn_str,           text_color=warn_col,     text_size=size.small)
        table.cell(info, 0, 5, "Timeframe",        text_color=color.silver, text_size=size.small)
        table.cell(info, 1, 5, str.tostring(math.round(tf_minutes)) + " min (ok)",
             text_color=color.green, text_size=size.small)
        table.cell(info, 0, 6, "Lookback",         text_color=color.silver, text_size=size.small)
        table.cell(info, 1, 6, str.tostring(lookback) + " Bars",
             text_color=color.silver, text_size=size.small)
